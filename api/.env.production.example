# ── EasyOrder API — Production Environment Variables ──────────────────────────
# Copy these into EasyPanel → Service → Environment Variables.
# Never commit the real values to git.

# PostgreSQL — use the internal host within EasyPanel (same project)
DATABASE_URL=postgres://postgres:CHANGE_ME@n8learning_postgres:5432/n8learning

# Supabase JWT secret (Settings → API → JWT Secret)
SUPABASE_JWT_SECRET=CHANGE_ME

# Port the API listens on (EasyPanel maps this to the external domain)
PORT=3001

NODE_ENV=production

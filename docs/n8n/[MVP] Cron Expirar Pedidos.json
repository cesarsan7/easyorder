      "name": "Extraer Contact ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2160,
        140
      ],
      "parameters": {
        "jsCode": "const searchResult = $input.first().json || {};\nconst loopItem = $('Loop Pedidos Expirados').first().json || {};\n\nlet contacts = [];\ntry {\n  const p = searchResult.payload;\n  if (Array.isArray(p)) contacts = p;\n  else if (p && Array.isArray(p.contacts)) contacts = p.contacts;\n} catch (e) {}\n\nconst contact = contacts.find(c => c && c.id) || null;\nconst contact_id = contact ? contact.id : null;\n\nreturn [{\n  json: {\n    contact_id,\n    tiene_contacto: contact_id !== null,\n    pedido_codigo: String(loopItem.pedido_codigo || ''),\n    pedido_id: loopItem.id,\n    telefono: String(loopItem.telefono || '')\n  }\n}];"
      }

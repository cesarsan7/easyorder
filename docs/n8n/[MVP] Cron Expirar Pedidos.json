    {
      "id": "34136136-5e25-413d-9065-cfd0cdce90e6",
      "name": "Preparar Mensaje Expiracion",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2880,
        60
      ],
      "parameters": {
        "jsCode": "const convsResult = $input.first().json || {};\nconst loopItem = $('Loop Pedidos Expirados').first().json || {};\n\nlet conversaciones = [];\ntry {\n  if (convsResult.data && convsResult.data.payload) {\n    conversaciones = convsResult.data.payload;\n  } else if (Array.isArray(convsResult.payload)) {\n    conversaciones = convsResult.payload;\n  } else if (Array.isArray(convsResult)) {\n    conversaciones = convsResult;\n  }\n} catch (e) {}\n\n// Conversación abierta o pendiente más reciente\nconst abierta = conversaciones\n  .filter(c => c && ['open', 'pending'].includes(c.status))\n  .sort((a, b) => (b.id || 0) - (a.id || 0))[0] || null;\n\nconst conversation_id = abierta ? abierta.id : null;\nconst pedido_codigo = String(loopItem.pedido_codigo || ('#' + loopItem.id));\nconst mensaje = `Tu pedido ${pedido_codigo} ha expirado por inactividad. Cuando quieras hacer un nuevo pedido, escr\\u00edbenos y te ayudamos.`;\n\nreturn [{\n  json: {\n    conversation_id,\n    tiene_conversacion: conversation_id !== null,\n    mensaje,\n    pedido_codigo,\n    telefono: String(loopItem.telefono || '')\n  }\n}];"
      }

# ── EasyOrder Web — Production Environment Variables ──────────────────────────
# NEXT_PUBLIC_* vars are baked into the JS bundle at build time.
# Set them as Build Args AND as Environment Variables in EasyPanel.

# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://xvoztrwupdxkghzfuzmd.supabase.co

# Supabase anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=CHANGE_ME

# Public URL of the deployed API service
NEXT_PUBLIC_API_URL=https://easyorder-api.ai2nomous.com

NODE_ENV=production
PORT=3000
